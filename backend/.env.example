# Copy this file to .env and fill in your values

# HuggingFace API token — get one at https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_your_token_here

# Database (SQLite by default; swap to PostgreSQL by changing this URL only)
DATABASE_URL=sqlite:///./data/chat.db
# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/open_chat

# Comma-separated allowed frontend origins
CORS_ORIGINS=http://localhost:3000
